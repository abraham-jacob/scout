[[source]]
url = "https://pypi.org/simple"
verify_ssl = true
name = "pypi"

[packages]
fastapi = "~=0.139"
uvicorn = {extras = ["standard"], version = "~=0.51"}
duckdb = "~=1.5"
python-dotenv = "~=1.2"
google-auth = "~=2.56"
google-auth-oauthlib = "~=1.4"
google-api-python-client = "~=2.198"
anthropic = "~=0.117"
jinja2 = "~=3.1"
python-multipart = "~=0.0"
httpx = "~=0.28"

[dev-packages]
pytest = "*"
pytest-cov = "~=4.0"
pytest-mock = "~=3.14"
pytest-asyncio = "*"
requests-mock = "*"

[requires]
python_version = "3.12"
python_full_version = "3.12.3"


[scripts]
unit-tests = "pipenv run pytest --junit-xml=junit_xml_test_report.xml --cov-report html --cov-branch --cov=agent --cov=app"
