[[source]]
url = "https://pypi.org/simple"
verify_ssl = true
name = "pypi"

[packages]
fastapi = "*"
uvicorn = {extras = ["standard"], version = "*"}
duckdb = "*"
python-dotenv = "*"
google-auth = "*"
google-auth-oauthlib = "*"
google-api-python-client = "*"
anthropic = "*"
jinja2 = "*"
python-multipart = "*"
httpx = "*"

[dev-packages]
pytest = "*"
pytest-cov = "~=4.0"
pytest-mock = "~=3.14"
pytest-asyncio = "*"
requests-mock = "*"

[requires]
python_version = "3.12"
python_full_version = "3.12.3"


[scripts]
unit-tests = "pipenv run pytest --junit-xml=junit_xml_test_report.xml --cov-report html --cov-branch --cov=agent --cov=app"
